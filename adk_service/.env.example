# ------------------------------------------------------------
# adk_service environment — copy to .env and fill in secrets
# ------------------------------------------------------------

# Groq API key (used via LiteLlm wrapper).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model routed through LiteLlm. Keep Llama 3.3 for parity with legacy googleADK/.
ADK_MODEL=groq/llama-3.3-70b-versatile

# FastAPI server config
HOST=0.0.0.0
PORT=8000

# CORS origins — the Express backend and React dev server
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173

# SQLite session DB (relative to adk_service/)
SESSION_DB_URL=sqlite+aiosqlite:///./sessions.db

# ADK / GenAI settings (tells ADK to skip Vertex, use direct API)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Weights & Biases (Weave) — LLM/agent pipeline tracing
# Grab key from https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=startup-validator
WANDB_ENTITY=
