# Backend Server Configuration

# Server
NODE_ENV=development
PORT=5000

# Database - MongoDB Atlas
MONGODB_URI=mongodb+srv://Dhoni:Dhoni@cluster0.utffa.mongodb.net/startup-validator?retryWrites=true&w=majority

# JWT Configuration
